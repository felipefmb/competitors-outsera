<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" packagingData="true">

    <!-- Lê valores do Spring -->
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="app"/>
    <springProperty scope="context" name="ENV" source="app.env" defaultValue="local"/>

    <!-- ===================== PROFILE: local (console TEXTO) ===================== -->
    <springProfile name="local">

        <!-- Registrar o conversor %kv (usa atributo 'class' para evitar warning) -->
        <conversionRule conversionWord="kv" class="br.com.felipefmb.competitors.infrastructure.configs.LoggerConfig"/>

        <appender name="CONSOLE_TEXT" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
                <!-- Exibe a mensagem e, se houver, o key-value 'payload' -->
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%thread] %cyan(%logger{36}) - %msg %kv{payload}%n</pattern>
            </encoder>
        </appender>

        <logger name="org.springframework" level="INFO"/>
        <logger name="com.zaxxer.hikari" level="INFO"/>
        <logger name="org.hibernate.SQL" level="WARN"/>

        <root level="INFO">
            <appender-ref ref="CONSOLE_TEXT"/>
        </root>
    </springProfile>

    <!-- ===================== PROFILE: dev, hom (console JSON) ===================== -->
    <springProfile name="dev,hom">
        <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
                <providers>
                    <!-- Básico -->
                    <timestamp><timeZone>UTC</timeZone></timestamp>
                    <logLevel/>
                    <loggerName/>
                    <threadName/>
                    <message/>
                    <stackTrace/>

                    <!-- MDC selecionado -->
                    <mdc>
                        <includeMdcKeyName>traceId</includeMdcKeyName>
                        <includeMdcKeyName>spanId</includeMdcKeyName>
                        <includeMdcKeyName>parentId</includeMdcKeyName>
                        <includeMdcKeyName>requestId</includeMdcKeyName>
                        <includeMdcKeyName>userId</includeMdcKeyName>
                        <includeMdcKeyName>method</includeMdcKeyName>
                        <includeMdcKeyName>path</includeMdcKeyName>
                        <includeMdcKeyName>clientIp</includeMdcKeyName>
                        <includeMdcKeyName>userAgent</includeMdcKeyName>
                        <includeMdcKeyName>app_name</includeMdcKeyName>
                        <includeMdcKeyName>env</includeMdcKeyName>
                    </mdc>

                    <!-- SLF4J 2 key-values / markers / args -->
                    <logstashMarkers/>
                    <keyValuePairs/>
                    <arguments>
                        <includeNonStructuredArguments>false</includeNonStructuredArguments>
                    </arguments>
                </providers>
            </encoder>
        </appender>

        <logger name="org.springframework" level="INFO"/>
        <logger name="com.zaxxer.hikari" level="INFO"/>
        <logger name="org.hibernate.SQL" level="WARN"/>

        <root level="INFO">
            <appender-ref ref="CONSOLE_JSON"/>
        </root>
    </springProfile>

    <!-- ===================== PROFILE: prod (console JSON + arquivo JSON) ===================== -->
    <springProfile name="prod">
        <!-- Console JSON -->
        <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
                <providers>
                    <timestamp><timeZone>UTC</timeZone></timestamp>
                    <logLevel/>
                    <loggerName/>
                    <threadName/>
                    <message/>
                    <stackTrace/>

                    <mdc>
                        <includeMdcKeyName>traceId</includeMdcKeyName>
                        <includeMdcKeyName>spanId</includeMdcKeyName>
                        <includeMdcKeyName>parentId</includeMdcKeyName>
                        <includeMdcKeyName>requestId</includeMdcKeyName>
                        <includeMdcKeyName>userId</includeMdcKeyName>
                        <includeMdcKeyName>method</includeMdcKeyName>
                        <includeMdcKeyName>path</includeMdcKeyName>
                        <includeMdcKeyName>clientIp</includeMdcKeyName>
                        <includeMdcKeyName>userAgent</includeMdcKeyName>
                        <includeMdcKeyName>app_name</includeMdcKeyName>
                        <includeMdcKeyName>env</includeMdcKeyName>
                    </mdc>

                    <logstashMarkers/>
                    <keyValuePairs/>
                    <arguments>
                        <includeNonStructuredArguments>false</includeNonStructuredArguments>
                    </arguments>
                </providers>
            </encoder>
        </appender>

        <!-- Arquivo JSON com rotação -->
        <appender name="FILE_JSON" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/app.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>logs/app-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>14</maxHistory>
                <totalSizeCap>5GB</totalSizeCap>
            </rollingPolicy>
            <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
                <providers>
                    <timestamp><timeZone>UTC</timeZone></timestamp>
                    <logLevel/>
                    <loggerName/>
                    <threadName/>
                    <message/>
                    <stackTrace/>

                    <mdc>
                        <includeMdcKeyName>traceId</includeMdcKeyName>
                        <includeMdcKeyName>spanId</includeMdcKeyName>
                        <includeMdcKeyName>parentId</includeMdcKeyName>
                        <includeMdcKeyName>requestId</includeMdcKeyName>
                        <includeMdcKeyName>userId</includeMdcKeyName>
                        <includeMdcKeyName>method</includeMdcKeyName>
                        <includeMdcKeyName>path</includeMdcKeyName>
                        <includeMdcKeyName>clientIp</includeMdcKeyName>
                        <includeMdcKeyName>userAgent</includeMdcKeyName>
                        <includeMdcKeyName>app_name</includeMdcKeyName>
                        <includeMdcKeyName>env</includeMdcKeyName>
                    </mdc>

                    <logstashMarkers/>
                    <keyValuePairs/>
                    <arguments>
                        <includeNonStructuredArguments>false</includeNonStructuredArguments>
                    </arguments>
                </providers>
            </encoder>
        </appender>

        <logger name="org.springframework" level="INFO"/>
        <logger name="com.zaxxer.hikari" level="INFO"/>
        <logger name="org.hibernate.SQL" level="WARN"/>

        <root level="INFO">
            <appender-ref ref="CONSOLE_JSON"/>
            <appender-ref ref="FILE_JSON"/>
        </root>
    </springProfile>

</configuration>
